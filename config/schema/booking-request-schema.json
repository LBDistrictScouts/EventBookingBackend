{
    "$id": "https://greenway.lbdscouts.org.uk/booking-request-schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": true,
    "properties": {
        "event_id": {
            "$ref": "#/definitions/uuid"
        },
        "entry_name": {
            "type": "string",
            "minLength": 1
        },
        "entry_email": {
            "type": "string",
            "format": "email"
        },
        "entry_mobile": {
            "type": "string"
        },
        "participants": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                    "id": {
                        "$ref": "#/definitions/uuid"
                    },
                    "access_key": {
                        "$ref": "#/definitions/uuid"
                    },
                    "first_name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "last_name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "participant_type_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "participant_type": {
                        "type": "string",
                        "minLength": 1
                    },
                    "section_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "section": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "required": [
                    "first_name",
                    "last_name"
                ]
            }
        }
    },
    "required": [
        "event_id",
        "entry_name",
        "entry_email",
        "entry_mobile",
        "participants"
    ],
    "definitions": {
        "uuid": {
            "type": "string",
            "minLength": 36,
            "pattern": "^[0-9a-f]{8}-([0-9a-f]{4}-){3}[0-9a-f]{12}$"
        }
    }
}
