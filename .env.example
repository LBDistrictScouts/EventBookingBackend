APP_NAME=event-booking-backend
DEBUG=true
APP_ENCODING=UTF-8
APP_DEFAULT_LOCALE=en_GB
APP_DEFAULT_TIMEZONE=Europe/London
APP_FULL_BASE_URL=http://localhost:8765
APP_FRONTEND_BASE_URL=http://localhost:5173

SECURITY_SALT=replace-with-a-long-random-string

# Used by the local Docker Compose `db` service, and by Compose-derived app DB URLs.
POSTGRES_DB=event_booking
POSTGRES_USER=event_booking_user
POSTGRES_PASSWORD=replace-with-a-database-password

# Used for non-Docker local runs such as `bin/cake server` on your host machine.
DATABASE_URL=postgres://event_booking_user:replace-with-a-database-password@127.0.0.1/event_booking?schema=data
DATABASE_TEST_URL=postgres://event_booking_user:replace-with-a-database-password@127.0.0.1/event_booking?schema=test

AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=
AWS_SQS_QUEUE_URL=
AWS_SQS_QUEUE_NAME=

COGNITO_DOMAIN=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_USER_POOL_ID=

SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_TIMEOUT=30
SMTP_TLS=true
SMTP_LOG=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_CLIENT=
EMAIL_TRANSPORT_SMTP_URL=

DISTRICT_CORE_DATA_URL=
DISTRICT_CORE_DATA_USERNAME=
DISTRICT_CORE_DATA_PASSWORD=
